name: Validate Integration Classes

on:
  push:
    branches:
      - beta
    paths:
      - 'custom_components/mg_saic/**.py'
  pull_request:
    branches:
      - main
    paths:
      - 'custom_components/mg_saic/**.py'

jobs:
  validate-classes:
    runs-on: ubuntu-latest
    name: AST class structure validation
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Check for duplicate __init__ and orphaned docstrings
        run: |
          python3 - <<'EOF'
import ast, sys, os

INTEGRATION_DIR = "custom_components/mg_saic"
errors = []

for filename in sorted(os.listdir(INTEGRATION_DIR)):
    if not filename.endswith(".py"):
        continue
    filepath = os.path.join(INTEGRATION_DIR, filename)
    with open(filepath) as f:
        source = f.read()
    try:
        tree = ast.parse(source)
    except SyntaxError as e:
        errors.append(f"{filepath}: SyntaxError: {e}")
        continue
    for node in ast.walk(tree):
        if not isinstance(node, ast.ClassDef):
            continue
        inits = [
            item for item in node.body
            if isinstance(item, ast.FunctionDef) and item.name == "__init__"
        ]
        if len(inits) > 1:
            lines = ", ".join(str(i.lineno) for i in inits)
            errors.append(
                f"{filepath}: class {node.name} (line {node.lineno}) "
                f"has {len(inits)} __init__ methods at lines {lines}"
            )
        for i, item in enumerate(node.body):
            if i == 0:
                continue
            if (
                isinstance(item, ast.Expr)
                and isinstance(item.value, ast.Constant)
                and isinstance(item.value.value, str)
            ):
                errors.append(
                    f"{filepath}: class {node.name} (line {node.lineno}) "
                    f"has an orphaned string literal at line {item.lineno} "
                    f"- likely a missing class declaration above it"
                )

if errors:
    print("\nINTEGRATION CLASS VALIDATION FAILED:\n")
    for e in errors:
        print(f"  ERROR: {e}")
    print("\nThis usually means a class declaration line was accidentally")
    print("dropped during a file edit. Check the lines listed above.")
    sys.exit(1)

class_count = sum(
    1 for filepath in [
        os.path.join(INTEGRATION_DIR, f)
        for f in os.listdir(INTEGRATION_DIR) if f.endswith(".py")
    ]
    for node in ast.walk(ast.parse(open(filepath).read()))
    if isinstance(node, ast.ClassDef)
)
print(f"OK - {class_count} classes across all integration files validated.")
print("No duplicate __init__ methods or orphaned docstrings found.")
EOF
